# ============================================
# AI SDK 环境变量配置
# ============================================

# 方案一：本地大模型 (Ollama) - 保留
OLLAMA_API_URL=http://127.0.0.1:1234
MODEL_NAME=llama3.2

# 方案二：OpenRouter API
OPENROUTER_API_KEY=""  # 设为空字符串则自动降级到本地 Ollama

# ============================================
# Claude Code / AI 助手配置
# ============================================
ANTHROPIC_BASE_URL=http://localhost:1234
ANTHROPIC_AUTH_TOKEN=lmstudio
ANTHROPIC_MODEL=qwen/qwen3.5-9b
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen/qwen3.5-9b
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen/qwen3.5-9b
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen/qwen3.5-9b
CLAUDE_CODE_EFFORT_LEVEL=max
ENABLE_TOOL_SEARCH=true

# ============================================
# 数据库配置（如果需要）
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=demodb
